# ──────────────────────────────────────────────────────────────
# Zerset Admin Panel – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# ──────────────────────────────────────────────────────────────

# Server port (default: 3000)
PORT=3000

# Node environment: development | production
NODE_ENV=development

# ── Admin credentials ─────────────────────────────────────────
# Admin username (default: admin)
ADMIN_USER=admin

# Preferred: bcrypt hash of the admin password (cost factor 12)
# Generate with: node -e "require('bcrypt').hash('yourpassword',12).then(console.log)"
# Example (do NOT use this in production – replace with your own hash):
ADMIN_PASSWORD_HASH=$2b$12$exampleSaltHereXXXXXXXexampleHashHereXXXXXXXXXXXXXXXXX

# Fallback (NOT recommended for production): plaintext password.
# The server will hash it on startup and emit a warning.
# ADMIN_PASSWORD=changeme

# ── Session security ──────────────────────────────────────────
# Random secret for signing session cookies.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=REPLACE_WITH_RANDOM_64_HEX_CHARS
